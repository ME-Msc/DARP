{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "tiny grid rollout",
      "type": "debugpy",
      "request": "launch",
      "module": "darp",
      "console": "integratedTerminal",
      "justMyCode": false,
      "python": "${workspaceFolder}/.venv/bin/python",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "MPLCONFIGDIR": "/tmp/darp-matplotlib"
      },
      "args": [
        "--domain",
        "experiments/inputs/rddl/tiny_grid_domain.rddl",
        "--instance",
        "experiments/inputs/rddl/tiny_grid_instance.rddl",
        "--planner",
        "rollout",
        "--rollout-lookahead-depth",
        "4",
        "--seed",
        "0",
        "--output",
        "/tmp/darp_tiny_grid_rollout.json"
      ]
    },
    {
      "name": "tiny grid full-ilp",
      "type": "debugpy",
      "request": "launch",
