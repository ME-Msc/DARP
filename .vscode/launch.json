    {
      "name": "tiny grid rollout",
      "type": "debugpy",
      "request": "launch",
      "module": "darp",
      "console": "integratedTerminal",
      "justMyCode": false,
      "python": "${workspaceFolder}/.venv/bin/python",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "MPLCONFIGDIR": "/tmp/darp-matplotlib"
      },
      "args": [
        "--domain",
        "examples/rddl/tiny_grid_domain.rddl",
        "--instance",
        "examples/rddl/tiny_grid_instance.rddl",
        "--planner",
        "rollout",
        "--rollout-lookahead-depth",
        "4",
        "--seed",
        "0",
        "--output",
